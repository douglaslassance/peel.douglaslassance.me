---
import '../styles/global.css';
import ThemeToggle from '../components/ThemeToggle.svelte';

const lastUpdated = "May 2, 2026";
---

<html lang="en" class="scroll-smooth">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" type="image/png" href="/icon.png" />
		<link rel="apple-touch-icon" href="/icon.png" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<title>Privacy Policy — Peel</title>
		<meta name="description" content="Privacy policy for the Peel macOS app." />

		<!-- Prevent dark mode flash -->
		<script is:inline>
			const saved = localStorage.getItem('theme');
			const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
			if (saved === 'dark' || (!saved && prefersDark)) {
				document.documentElement.classList.add('dark');
			}
		</script>
	</head>
	<body class="min-h-screen flex flex-col">
		<div class="fixed top-4 right-4 z-50">
			<ThemeToggle client:load />
		</div>

		<main class="flex-1 w-full max-w-3xl mx-auto px-8 pt-24 pb-16">
			<h1 class="text-4xl font-bold tracking-tight mb-2">Privacy Policy</h1>
			<p class="text-sm text-muted-foreground mb-12">Last updated: {lastUpdated}</p>

			<section class="space-y-4 mb-10">
				<p class="text-base leading-relaxed">
					Peel is a macOS application that helps you browse and organize files using tags. This policy describes what data Peel handles and how.
				</p>
				<p class="text-base leading-relaxed">
					<strong>Short version:</strong> Peel does not collect personal data, does not use analytics or tracking, and does not send your files or tags anywhere. Everything stays on your Mac.
				</p>
			</section>

			<section class="space-y-3 mb-10">
				<h2 class="text-xl font-semibold tracking-tight">Data stored on your device</h2>
				<p class="text-base leading-relaxed">
					Tags, security-scoped bookmarks, and app preferences are stored locally on your Mac. They are not transmitted to Peel or any third party. Uninstalling the app removes Peel's data from your device.
				</p>
			</section>

			<section class="space-y-3 mb-10">
				<h2 class="text-xl font-semibold tracking-tight">Network connections</h2>
				<p class="text-base leading-relaxed">
					Peel connects to the network only for the following purposes:
				</p>
				<ul class="list-disc pl-6 space-y-2 text-base leading-relaxed">
					<li>
						<strong>Software updates</strong> (non–Mac App Store builds only). Peel periodically checks for new versions by fetching an update feed from <code class="text-sm">storage.douglaslassance.me</code>. The request includes only the information typically present in any HTTP request (such as your IP address and macOS version) and is not used for tracking.
					</li>
					<li>
						<strong>In-App Purchases</strong> (Mac App Store builds only). Purchases and receipt validation are handled by Apple's StoreKit framework. Peel never sees your payment information. Apple's privacy policy applies: <a href="https://www.apple.com/legal/privacy/" class="underline underline-offset-4 decoration-foreground/30 hover:decoration-foreground transition-colors">apple.com/legal/privacy</a>.
					</li>
				</ul>
			</section>

			<section class="space-y-3 mb-10">
				<h2 class="text-xl font-semibold tracking-tight">Files and folders</h2>
				<p class="text-base leading-relaxed">
					Peel reads files and folders that you explicitly grant access to via the macOS sandbox. File contents are processed entirely on your Mac for previews, waveform generation, and tag suggestions. No file content is uploaded.
				</p>
			</section>

			<section class="space-y-3 mb-10">
				<h2 class="text-xl font-semibold tracking-tight">Analytics and tracking</h2>
				<p class="text-base leading-relaxed">
					Peel does not use analytics, telemetry, crash reporting, or advertising SDKs. There is no data collection.
				</p>
			</section>

			<section class="space-y-3 mb-10">
				<h2 class="text-xl font-semibold tracking-tight">Children</h2>
				<p class="text-base leading-relaxed">
					Peel is not directed at children under 13 and does not knowingly collect any data from them.
				</p>
			</section>

			<section class="space-y-3 mb-10">
				<h2 class="text-xl font-semibold tracking-tight">Changes to this policy</h2>
				<p class="text-base leading-relaxed">
					If this policy changes, the updated version will be posted on this page with a new "Last updated" date.
				</p>
			</section>

			<section class="space-y-3 mb-10">
				<h2 class="text-xl font-semibold tracking-tight">Contact</h2>
				<p class="text-base leading-relaxed">
					Questions or concerns? Email <a href="mailto:hey@douglaslassance.me" class="underline underline-offset-4 decoration-foreground/30 hover:decoration-foreground transition-colors">hey@douglaslassance.me</a>.
				</p>
			</section>
		</main>

		<footer class="p-8">
			<div class="flex flex-col md:flex-row justify-between items-center gap-4 w-full max-w-4xl mx-auto">
				<p class="text-sm text-muted-foreground">
					© 2026 <a href="https://douglaslassance.me" target="_blank" rel="noopener" class="underline underline-offset-4 decoration-foreground/30 hover:decoration-foreground transition-colors">Douglas Lassance</a>
				</p>
				<div class="flex gap-4 items-center">
					<a href="/" class="text-sm text-muted-foreground underline underline-offset-4 decoration-foreground/30 hover:decoration-foreground transition-colors">Home</a>
				</div>
			</div>
		</footer>
	</body>
</html>
