---
import '../styles/global.css';
import { Search, FileText, Image, Apple, Copy, Check, Sun, Moon } from 'lucide-astro';
import FeatureCard from '../components/FeatureCard.astro';

const description = "Peel transforms how you browse your files. By handling tags like folders, you retain all their flexibility while not compromising on discoverability.";
---

<html lang="en" class="scroll-smooth" data-theme="peel">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/png" href="/icon.png" />
		<link rel="apple-touch-icon" href="/icon.png" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<title>Peel</title>
		<meta name="description" content={description} />
		
		<!-- Open Graph -->
		<meta property="og:type" content="website" />
		<meta property="og:title" content="Peel" />
		<meta property="og:description" content={description} />
		<meta property="og:image" content="https://peel.douglaslassance.me/icon.png" />
		<meta property="og:url" content="https://peel.douglaslassance.me" />
		
		<!-- Twitter Card -->
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content="Peel - Browse Files with Tags Like Folders" />
		<meta name="twitter:description" content={description} />
		<meta name="twitter:image" content="https://peel.douglaslassance.me/icon.png" />
		<style>
			@keyframes fadeInUp {
				from {
					opacity: 0;
					transform: translateY(30px);
				}
				to {
					opacity: 1;
					transform: translateY(0);
				}
			}

			@keyframes fadeIn {
				from {
					opacity: 0;
				}
				to {
					opacity: 1;
				}
			}

			@keyframes float {
				0%, 100% {
					transform: translateY(0);
				}
				50% {
					transform: translateY(-10px);
				}
			}
			
			.animate-fade-in {
				animation: fadeIn 0.8s ease-out;
			}
			
			.animate-fade-in-up {
				animation: fadeInUp 0.8s ease-out backwards;
			}
			
			.animate-float {
				animation: float 3s ease-in-out infinite;
			}
			
			[data-delay="0.2s"] {
				animation-delay: 0.2s;
			}
			
			[data-delay="0.4s"] {
				animation-delay: 0.4s;
			}
			
			[data-delay="0.5s"] {
				animation-delay: 0.5s;
			}
			
			[data-delay="0.7s"] {
				animation-delay: 0.7s;
			}
			
			[data-delay="0.85s"] {
				animation-delay: 0.85s;
			}
			
			[data-delay="1s"] {
				animation-delay: 1s;
			}
			
			[data-delay="1.2s"] {
				animation-delay: 1.2s;
			}
		</style>
	</head>
	<body class="min-h-screen flex flex-col">
		<!-- Theme Switcher -->
		<div class="fixed top-4 right-4 z-50">
			<label class="swap swap-rotate btn btn-ghost btn-circle">
				<input type="checkbox" class="theme-controller" value="peel-dark" />
				<Sun class="swap-off size-5" />
				<Moon class="swap-on size-5" />
			</label>
		</div>
		
		<main class="flex-1 flex flex-col">
			<!-- Hero Section -->
			<div class="flex-1 flex flex-col items-center justify-center px-8 py-16 text-center max-w-3xl mx-auto animate-fade-in">
				<div class="hover-3d mt-24 mb-2">
					<img src="/icon.png" alt="Peel app icon - a stylized purple tag symbol" class="w-[200px] h-[200px] icon-shadow" />
					<div></div>
					<div></div>
					<div></div>
					<div></div>
					<div></div>
					<div></div>
					<div></div>
					<div></div>
				</div>
				<h1 class="text-6xl font-bold mb-0 tracking-tight text-base-content animate-fade-in-up" data-delay="0.2s">Peel</h1>
			</div>

			<!-- Features Section -->
			<div class="w-full max-w-5xl mx-auto px-8 pb-8 animate-fade-in" data-delay="0.4s">
				<!-- Hero Card -->
				<div class="card bg-base-100 shadow-2xl mb-8 hover:-translate-y-1 transition-all duration-300 animate-fade-in-up" data-delay="0.5s">
					<div class="card-body items-center text-center">
						<div class="mb-4 text-primary" aria-hidden="true">
							<Search size={48} />
						</div>
						<h2 class="card-title text-3xl">Browse different</h2>
						<p class="text-lg text-base-content/70 max-w-2xl mb-5">{description}</p>
					</div>
				</div>

				<!-- Feature Grid -->
				<div class="grid grid-cols-1 md:grid-cols-2 gap-8">
					<FeatureCard 
						icon={FileText}
						title="Works with your files"
						description="Peel is not opinionated, it works with any file living anywhere on your system."
						delay="0.7s"
					/>
					<FeatureCard 
						icon={Image}
						title="Great media support"
						description="Beautiful previews for images, movies, GIFs, audio files, and more."
						delay="0.85s"
					/>
				</div>
			</div>

			<!-- Actions Section -->
			<div class="text-center py-12 animate-fade-in-up" data-delay="1s">
	<a href="https://apps.apple.com/app/peel" target="_blank" rel="noopener" aria-label="Purchase Peel on the App Store (opens in new window)" class="btn btn-primary btn-lg">
				<img src="/apple.svg" class="size-[1.2em] icon-button-primary" aria-hidden="true" />
					Purchase on App Store
				</a>
			</div>

			<!-- Download Section -->
			<div class="w-full max-w-5xl mx-auto px-8 pb-16 animate-fade-in-up" data-delay="1.2s">
				<div class="text-center max-w-2xl mx-auto">
					<h2 class="text-2xl font-semibold mb-4">or install for free with Homebrew</h2>
				<div class="flex items-center justify-between bg-code-field bg-base-200 border border-base-300 rounded-lg px-5 py-4 mt-4">
						<code class="flex-1 text-left font-mono">brew install --cask peel</code>
						<button onclick="copyToClipboard('brew install --cask peel', this)" aria-label="Copy Homebrew command to clipboard" class="btn btn-ghost btn-sm">
							<span class="sr-only">Copy to clipboard</span>
							<Copy size={16} aria-hidden="true" />
						</button>
					</div>
				</div>
			</div>

			<!-- Spacer -->
			<div class="h-16 md:h-32"></div>
		</main>

		<!-- Footer -->
	<footer class="footer footer-center p-8 bg-base-200">
			<div class="flex flex-col md:flex-row justify-between items-center gap-4 w-full max-w-5xl">
			<p class="text-sm">© 2026 <a href="https://douglaslassance.me" target="_blank" rel="noopener" class="link link-hover link-primary">Douglas Lassance</a></p>
				<div class="flex gap-4 items-center">
					<a href="https://ko-fi.com/douglaslassance" target="_blank" rel="noopener" class="opacity-80 hover:opacity-100 hover:scale-110 transition-all duration-200" aria-label="Support on Ko-fi (opens in new window)">
						<img src="/ko-fi.svg" alt="" width="24" height="24" class="icon-invert" />
					</a>
					<a href="https://www.producthunt.com/posts/peel" target="_blank" rel="noopener" class="opacity-80 hover:opacity-100 hover:scale-110 transition-all duration-200" aria-label="View on Product Hunt (opens in new window)">
						<img src="/product-hunt.svg" alt="" width="24" height="24" class="icon-invert" />
					</a>
				</div>
			</div>
		</footer>

		<script is:inline>
			// Theme switcher
			const themeController = document.querySelector('.theme-controller');
			const html = document.documentElement;
			
			// Load saved theme or use default
			const savedTheme = localStorage.getItem('theme') || 'peel';
			html.setAttribute('data-theme', savedTheme);
			if (themeController && savedTheme === 'peel-dark') {
				themeController.checked = true;
			}
			
			// Handle theme toggle
			if (themeController) {
				themeController.addEventListener('change', (e) => {
					const newTheme = e.target.checked ? 'peel-dark' : 'peel';
					html.setAttribute('data-theme', newTheme);
					localStorage.setItem('theme', newTheme);
				});
			}
		</script>

		<script is:inline>
			function copyToClipboard(text, button) {
				navigator.clipboard.writeText(text).then(() => {
					if (button) {
						const originalHTML = button.innerHTML;
						button.innerHTML = '<span class="sr-only">Copied!</span><svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 6 9 17l-5-5"/></svg>';
						setTimeout(() => {
							button.innerHTML = originalHTML;
						}, 2000);
					}
				}).catch((err) => {
					console.error('Failed to copy text: ', err);
				});
			}
		</script>
	</body>
</html>
